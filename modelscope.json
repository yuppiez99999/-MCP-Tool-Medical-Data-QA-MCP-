{
  "name": "medical-data-qa-mcp",
  "display_name": "医疗数据质量评估 MCP Tool",
  "description": "基于医疗Token数据的智能质量评估+循证医学工具。支持4维度质量评分、8大科室ML自动分类、循证文献检索、带引用的质量报告生成。可被任何AI Agent调用。",
  "version": "2.0.0",
  "license": "MIT",
  "author": "小X宝医疗黑客松参赛团队",
  "tags": ["医疗", "数据质量", "MCP", "Agent Skill", "循证医学", "科室分类", "AI辅助"],
  "category": "healthcare",
  "tools": [
    {
      "name": "assess_data_quality",
      "description": "评估医疗数据质量：完整性、准确性、时效性、合规性4维度评分，返回综合质量分和A/B/C/D等级",
      "inputSchema": {
        "type": "object",
        "properties": {
          "records": {"type": "array", "items": {"type": "object"}, "description": "待评估的医疗数据记录列表"},
          "department": {"type": "string", "description": "可选，按科室筛选"}
        },
        "required": ["records"]
      }
    },
    {
      "name": "classify_department",
      "description": "自动识别医疗数据所属科室（ML模型+规则引擎双引擎，支持放射科/心血管科/神经内科等8大科室）",
      "inputSchema": {
        "type": "object",
        "properties": {
          "record": {"type": "object", "description": "含text/data_type字段的医疗数据记录"}
        },
        "required": ["record"]
      }
    },
    {
      "name": "grade_data_level",
      "description": "根据综合质量分评定数据等级（A/B/C/D四级），含推荐用途与定价系数",
      "inputSchema": {
        "type": "object",
        "properties": {
          "quality_score": {"type": "number", "description": "综合质量评分(0-100)"}
        },
        "required": ["quality_score"]
      }
    },
    {
      "name": "generate_quality_report",
      "description": "生成完整医疗数据质量报告：科室分布、维度分析、改进建议",
      "inputSchema": {
        "type": "object",
        "properties": {
          "records": {"type": "array", "items": {"type": "object"}, "description": "数据记录列表"},
          "dataset_name": {"type": "string", "description": "数据集名称", "default": "未命名数据集"}
        },
        "required": ["records"]
      }
    },
    {
      "name": "search_similar_data",
      "description": "检索与给定质量画像相似的历史数据记录（欧氏距离匹配）",
      "inputSchema": {
        "type": "object",
        "properties": {
          "quality_profile": {"type": "object", "description": "质量维度画像"},
          "department": {"type": "string", "description": "可选，按科室筛选"},
          "top_k": {"type": "integer", "description": "返回数量", "default": 10}
        },
        "required": ["quality_profile"]
      }
    },
    {
      "name": "search_medical_evidence",
      "description": "KnowS循证医学检索：支持英文论文/中文论文/临床指南/临床试验/药品说明书6种数据源",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {"type": "string", "description": "检索关键词"},
          "source": {"type": "string", "description": "数据源: paper_en/paper_cn/guide/clinical_trial/drug_label", "default": "paper_en"},
          "max_results": {"type": "integer", "description": "返回数量", "default": 10}
        },
        "required": ["query"]
      }
    },
    {
      "name": "assess_with_evidence",
      "description": "质量评估+文献检索联动：评估质量的同时自动检索相关循证医学文献",
      "inputSchema": {
        "type": "object",
        "properties": {
          "records": {"type": "array", "items": {"type": "object"}, "description": "待评估数据记录"},
          "query": {"type": "string", "description": "自定义检索词（可选，不填则自动生成）", "default": ""},
          "source": {"type": "string", "description": "文献数据源: paper_en/paper_cn/guide/trial/package_insert", "default": "paper_en"},
          "department": {"type": "string", "description": "可选，按科室筛选"},
          "evidence_count": {"type": "integer", "description": "返回文献数量", "default": 5}
        },
        "required": ["records"]
      }
    },
    {
      "name": "generate_evidence_based_report",
      "description": "生成带循证医学文献引用的完整质量报告",
      "inputSchema": {
        "type": "object",
        "properties": {
          "records": {"type": "array", "items": {"type": "object"}, "description": "数据记录列表"},
          "dataset_name": {"type": "string", "description": "数据集名称", "default": "未命名数据集"},
          "department": {"type": "string", "description": "可选，按科室筛选"},
          "evidence_per_dimension": {"type": "integer", "description": "每个维度引用文献数", "default": 2},
          "source": {"type": "string", "description": "文献数据源: paper_en/paper_cn/guide/trial", "default": "paper_en"}
        },
        "required": ["records"]
      }
    }
  ],
  "deployment": {
    "type": "modelscope_space",
    "space_sdk": "gradio",
    "app_file": "app.py",
    "requirements_file": "requirements_space.txt",
    "python_version": "3.10"
  }
}
