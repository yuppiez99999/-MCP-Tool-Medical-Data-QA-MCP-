# 小X宝医疗黑客松 2026 — 环境变量配置模板
#
# 使用说明：
#   1. 复制本文件为 .env：  copy .env.example .env
#   2. 填入你的真实 API Key
#   3. .env 文件已加入 .gitignore，不会被提交到 Git

# KnowS 医学循证证据检索 API Key
# 获取地址：https://www.medknows.com
KNOWS_API_KEY=your-knows-api-key-here

# KnowS API 基础地址（可选，使用默认值即可）
# KNOWS_BASE_URL=https://api.nullht.com/v1
